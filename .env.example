# Vault Obsidian — choisir selon l'environnement
# Sur le VPS (production) :
VAULT_PATH=/home/vincent/obsidian-second-brain-vps
# En local (développement) — commenter VAULT_PATH et décommenter :
# LOCAL_VAULT_PATH=/home/vincent/obsidian-second-brain

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_WIKI=gemini-2.5-flash

# Bridges — sources des extracteurs
MEDIUM_EXTRACT_OUTPUT=/home/vincent/dev/medium_extract/output
SUBSTACK_EXTRACT_OUTPUT=/home/vincent/dev/substack_extract/output

# Recherche sémantique (optionnel)
ENABLE_SEMANTIC_SEARCH=false

# Logging
LOG_LEVEL=INFO
